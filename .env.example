# Walform — Environment Variables
# Copy to .env.local in apps/web/ and fill in values.

# Network: "testnet" or "mainnet"
NEXT_PUBLIC_SUI_NETWORK=testnet

# Published Move package ID (from `sui client publish` output)
NEXT_PUBLIC_WALFORM_PACKAGE_ID=0x74254b034b8cdfc6cb5da2551ed4db8d5eae202cf858b741a7736f85bf9836f1

# Demo form object ID (from seed-demo-form script)
NEXT_PUBLIC_WALFORM_DEMO_FORM_ID=0x06dfe1544f18e2709ba2717dc5ed144f95f7cc95615aeb9009700db95935be50
